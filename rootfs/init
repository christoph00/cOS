#!/bin/sh
set -ex

LOGFILE="/initrd.log"

log()    { printf "➜ %s\n" "$*" | tee -a "$LOGFILE"; }
log_suc(){ printf "✓ %s\n" "$*" | tee -a "$LOGFILE"; }
log_err(){ printf "✗ %s\n" "$*" | tee -a "$LOGFILE" >&2; }

# Ensure the logfile exists and is writable
touch "$LOGFILE" 2>/dev/null || LOGFILE="/dev/null"

# Ensure PATH includes essential binaries

/bin/busybox mkdir -p \
	/bin \
	/sbin \
	/usr/bin \
	/usr/sbin \
	/proc \
	/sys \
	/dev \
	/tmp \
	/etc
/bin/busybox --install -s
export PATH=/bin:/sbin:/usr/bin:/usr/sbin

log "Start init"

try_mount() {
    local type=$1 opts=$2 src=$3 dst=$4
    local retries=5 count=0
    while [ $count -lt $retries ]; do
        if mount -t "$type" -o "$opts" "$src" "$dst" 2>>"$LOGFILE"; then
            log_suc "Mounted $dst ($type)"
            return 0
        else
            log_err "Mount failed: $dst ($type), attempt $((count + 1))"
            sleep 1
            count=$((count + 1))
        fi
    done
    log_err "Giving up mounting $dst ($type) after $retries attempts"
    return 1
}

log "Mounting filesystems"
try_mount sysfs    "noexec,nosuid,nodev" sysfs  /sys
( try_mount devtmpfs "exec,nosuid,mode=0755,size=2M" devtmpfs /dev  || \
  try_mount tmpfs    "exec,nosuid,mode=0755,size=2M" tmpfs   /dev )
try_mount proc      "noexec,nosuid,nodev" proc   /proc

[ -d /dev/pts ] || mkdir -m 755 /dev/pts
try_mount devpts    "gid=5,mode=0620,noexec,nosuid" devpts /dev/pts

: ${ZRAM_SIZE:=600M}
: ${ROOT_FSTYPE:=ext4}
: ${ROOT_DEV:=/dev/disk/by-label/ESP}
: ${ROOT_ARCHIVE:=rootfs.tar.gz}

log "Loading kernel modules ..."
for mod in virtio_pci virtio_blk virtio_scsi virtio_ring virtio_rng virtio_console \
           zram ext4 vfat \
           simpledrm \
           ata_piix ata_generic libata \
           sd_mod sr_mod uhci_hcd ehci_hcd usb_storage \
	   scsi \
           floppy; do
    if modprobe "$mod" 2>>"$LOGFILE"; then
        log_suc "modprobe $mod"
    else
        log_err "modprobe $mod (non-critical)"
    fi
done

TIMEOUT=30 INTERVAL=1 ELAPSED=0

log "Waiting for /dev/zram0 ..."
while [ ! -e /dev/zram0 ]; do
    sleep "$INTERVAL"
    ELAPSED=$((ELAPSED + INTERVAL))
    if [ "$ELAPSED" -ge "$TIMEOUT" ]; then
        log_err "Timeout: /dev/zram0 not found after $TIMEOUT seconds."
        exec sh
    fi
done

log "Running mdev"
echo /sbin/mdev >/proc/sys/kernel/hotplug 
/sbin/mdev -s

mem_total_kb=$(awk '/MemTotal/ {print $2}' /proc/meminfo)
zram_size_kb=$((mem_total_kb * 8 / 10))
log "Configuring ZRAM (${zram_size_kb}K)"
echo "${zram_size_kb}K" > /sys/block/zram0/disksize

if ! /sbin/mkfs.$ROOT_FSTYPE -L root /dev/zram0 >>"$LOGFILE" 2>&1; then
    log_err "mkfs on /dev/zram0 failed"
    exec sh
fi
mkdir -p /mnt/zram_root /mnt/alpine_dev

if ! try_mount "$ROOT_FSTYPE" "defaults" /dev/zram0 /mnt/zram_root; then
    log_err "Mounting zram root failed"
    exec sh
fi
log_suc "Root zram formatted and mounted"

for dir in bin etc usr lib sbin; do
  [ -d "/$dir" ] && cp -a "/$dir" /mnt/zram_root/
done

for dev in /dev/sda /dev/vda; do
  [ -b "$dev" ] && DISK="$dev" && break
done

[ -z "${DISK:-}" ] && log_err "No Valid Disk found." && exec sh

if [ ! -b "/dev/disk/by-label/data" ]; then
  log "No Disk with Label data found. Formatting $DISK ..."

  sgdisk -Zo "$DISK"

  sgdisk -n 1:1M:+512M -t 1:ef00 "$DISK"
  sgdisk -n 2:0:+2G -t 2:8200 "$DISK"
  sgdisk -n 3:0:0 -t 3:8300 "$DISK"

  partprobe "$DISK"
  sleep 2

  EFI="${DISK}1"
  SWAP="${DISK}2"
  BTRFS="${DISK}3"

  mkfs.vfat -n ESP -F32 "$EFI"
  mkswap "$SWAP"
  swapon "$SWAP"
  mkfs.btrfs -f -L data "$BTRFS"

  mkdir -p /mnt/data
  mdev -s
  mount -t btrfs "$BTRFS" /mnt/data
  sleep 0.1
  btrfs subvolume create /mnt/data/@etc
  btrfs subvolume create /mnt/data/@var
  btrfs subvolume create /mnt/data/@home

  ls -lah /mnt/data

  umount /mnt/data
fi


mkdir -p /mnt/zram_root/var
mount -t btrfs -o subvol=@var -o compress-force=zstd /dev/disk/by-label/data /mnt/zram_root/var
mkdir -p /mnt/zram_root/home
mount -t btrfs -o subvol=@home -o compress-force=zstd /dev/disk/by-label/data /mnt/zram_root/home
mkdir -p /mnt/etc-persist
mount -t btrfs -o subvol=@etc -o compress-force=zstd /dev/disk/by-label/data /mnt/etc-persist

if [ -d /mnt/etc-persist/.git ]; then
  git --git-dir=/mnt/etc-persist/.git --work-tree=/mnt/zram_root/etc checkout -f
fi

umount /mnt/etc-persist


log "Switching root"
if [ ! -x "/mnt/zram_root/sbin/init" ]; then
    log_err "Missing /sbin/init in new root"
    exec sh
fi

mkdir -p /mnt/zram_root/dev /mnt/zram_root/proc /mnt/zram_root/sys /mnt/zram_root/run

mount --move /dev  /mnt/zram_root/dev
mount --move /proc /mnt/zram_root/proc
mount --move /sys  /mnt/zram_root/sys

exec < /mnt/zram_root/dev/console > /mnt/zram_root/dev/console 2>&1
exec switch_root -c /dev/console /mnt/zram_root /sbin/init

log_err "Switch_root failed, dropping to a shell"
exec sh

