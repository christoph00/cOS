#!/bin/sh

set -eu


# Color codes (optional)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print info messages
info() {
    printf "${GREEN}[INFO]${NC} %s\n" "$1"
}

# Function to print error messages
error() {
    printf "${RED}[ERROR]${NC} %s\n" "$1" >&2
}

# Function to print warning messages
warn() {
    printf "${YELLOW}[WARNING]${NC} %s\n" "$1"
}


info "Mounting ESP"
mkdir /esp
mount /dev/disk/by-label/ESP /esp

OWNER="christoph00"
REPO="cOS"
API_URL="https://api.github.com/repos/${OWNER}/${REPO}/releases/latest"

# Temporary file for JSON response
TMP_JSON=$(mktemp)
trap 'rm -f "$TMP_JSON"' EXIT

info "Fetching latest release info for ${OWNER}/${REPO}..."

# Query GitHub API
if ! wget -qO "$TMP_JSON" "$API_URL"; then
    error "Failed to fetch release info. Is the repository valid or private?"
    exit 1
fi

# Ensure jq is installed
if ! command -v jq >/dev/null 2>&1; then
    error "jq not found. Please install jq to parse JSON."
    exit 1
fi

# Extract release tag
TAG=$(jq -r '.tag_name' "$TMP_JSON")
if [ -z "$TAG" ] || [ "$TAG" = "null" ]; then
    error "No release found."
    exit 1
fi

info "Latest release: $TAG"

# Detect architecture
ARCH=$(uname -m)
case "$ARCH" in
    x86_64)
        ARCH="amd64"
        ;;
    aarch64)
        ARCH="arm64"
        ;;
    *)
        error "Unsupported architecture: $ARCH"
        exit 1
        ;;
esac

info "Detected architecture: $ARCH"

# Files to download
FILES="os-${ARCH}.efi rootfs-${ARCH}.tar.gz"

for F_PATTERN in $FILES; do
    F_TARGET=$(echo "$F_PATTERN" | sed "s/-${ARCH}//")
    info "Looking for $F_PATTERN..."
    
    # Get download URL for the file
    URL=$(jq -r --arg name "$F_PATTERN" '.assets[] | select(.name == $name) | .browser_download_url' "$TMP_JSON")
    
    if [ -z "$URL" ] || [ "$URL" = "null" ]; then
        warn "File $F_PATTERN not found in release $TAG."
        continue
    fi

    info "Backup old $F_TARGET..."
    if [ -f "/esp/$F_TARGET" ]; then
        mv "/esp/$F_TARGET" "/esp/backup_$F_TARGET"
    fi
    
    info "Downloading $F_PATTERN to $F_TARGET..."
    if wget -O "/esp/$F_TARGET" "$URL"; then
        info "✔ $F_PATTERN downloaded successfully"
        SIZE=$(ls -lh "/esp/$F_TARGET" | awk '{print $5}')
        info "  Size: $SIZE"
    else
        error "✖ Download failed for $F_PATTERN"
        exit 1
    fi
done

info "Unmount ESP"
umount /esp
rm -rf /esp

info "Upgrade complete!"
