#!/sbin/openrc-run

depend() {
    need localmount
    need networking
    before sshd
}

start_pre() {
    ebegin "Creating Dirs in /var"
    mkdir -p /var/lib/monit/state
    mkdir -p /var/lib/containers
    eend 0


    ebegin "Creating user 'core' and adding to wheel group"
    if ! getent passwd core >/dev/null; then
        adduser -h /home/core -G wheel -s /bin/ash -D core \
          || { eend 1 "Failed to create user 'core'"; return 1; }
	PASSWD=$(head -c 32 /dev/urandom | base64 | head -c 16)
    	echo "core:$PASSWD" | chpasswd \
          || { eend 1 "Failed to set password for user 'core'"; return 1; }
    fi
    eend 0

    ebegin "Downloading SSH keys for 'core'"
    mkdir -p /etc/ssh/authorized_keys
    wget -qO /etc/ssh/authorized_keys/core \
         https://github.com/christoph00.keys \
        || { eend 1 "Failed to download SSH keys"; return 1; }
    chmod 600 /etc/ssh/authorized_keys/core
    chown core /etc/ssh/authorized_keys/core
    eend 0

    ebegin "Checking/creating SSH host keys in /var/lib/ssh"
    install -d -m 700 /var/lib/ssh
    for t in rsa ed25519 ecdsa; do
        key="/var/lib/ssh/ssh_host_${t}_key"
        pub="${key}.pub"
        if [ ! -f "$key" ]; then
            ssh-keygen -t "$t" -f "$key" -N "" \
                || { eend 1 "Error generating $t host key"; return 1; }
            chmod 600 "$key" "$pub"
        fi
    done
    eend 0
}

start() {
    # ebegin "Reading and setting hostname from /var/config.json"
    # HOSTNAME=$(jq -r '.hostname' /var/config.json 2>/dev/null) \
    #     || { eend 1 "Error reading hostname"; return 1; }
    # if [ -n "$HOSTNAME" ]; then
    #     echo "$HOSTNAME" > /etc/hostname
    #     hostname "$HOSTNAME"
    # fi
    # eend 0

    ebegin "Install Packages"
    apk add podman htop
    eend 0
}
